# ============================================
# Environment Variable Configuration
# Copy to .env and fill in values:
#   cp .env.example .env
# ============================================

# --- Flask ---
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-random-64-char-string-in-production

# --- Database ---
DATABASE_URL=postgresql://ids_user:ids_secure_password_change_me@localhost:5432/ids_db
DATABASE_TEST_URL=postgresql://ids_user:ids_secure_password_change_me@localhost:5432/ids_test_db

# --- Database Pool ---
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# --- Email (SMTP) ---
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=ids@example.com

# --- Threat Intelligence ---
ABUSEIPDB_API_KEY=
ABUSEIPDB_RATE_LIMIT=1000

# --- Packet Capture ---
CAPTURE_INTERFACE=eth0
CAPTURE_BPF_FILTER=not (ether broadcast or ether multicast)
PACKET_QUEUE_SIZE=10000
BATCH_INSERT_SIZE=500
BATCH_FLUSH_INTERVAL_MS=500

# --- Detection Thresholds (overrides YAML config) ---
# These can also be set via config/thresholds.yaml

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# --- JWT ---
JWT_SECRET_KEY=change-this-to-another-random-64-char-string
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800

# --- Admin Seed User ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123!
